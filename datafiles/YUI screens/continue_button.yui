id: continue_button
file_type: screen

import:
  - ../Templates/

  - /YUI/Animations/transitions.yui
  - /YUI/Widgets/

root:
  type: panel
  layout: canvas 
  theme: elektra
  elements:
    - type: panel
      alignment: center
      canvas:
        center: h
      elements:
        - type: button
          background: ~spButton
          border_thickness: 0
          content:
            type: text
            text: Continue
          on_click:
            - ~flow_continue()
